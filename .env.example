# ─── 管理员 API (EchoTech) ───
ECHOTECH_API_KEY=your_api_key_here
ECHOTECH_BASE_URL=https://llm.echo.tech/v1
ENHANCE_MODEL=claude-sonnet-4-6

# ─── 管理员图片生成 (TAMS API) ───
TAMS_TOKEN=your_tams_token_here

# ─── 平台基础设施 ───
TENSORART_BEARER_TOKEN=your_tensorart_bearer_token_here
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# ─── Supabase (认证 + 用户 Key 存储) ───
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── API Key 加密 (openssl rand -hex 32) ───
KEY_ENCRYPTION_SECRET=your_64_char_hex_here

PORT=3000
